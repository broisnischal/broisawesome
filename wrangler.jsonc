{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio",
  "compatibility_date": "2025-04-04",
  "main": "./workers/app.ts",
  "route": "*.nischal-dahal.com.np/*",
  "vars": {
    "VALUE_FROM_CLOUDFLARE": "Hello from Cloudflare"
  },
  "compatibility_flags": [
    "nodejs_compat",
    "nodejs_als"
  ]
}